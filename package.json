{
    "name": "@weblab/repo",
    "version": "0.0.1",
    "description": "Weblab Monorepo",
    "homepage": "https://weblab.build",
    "license": "Apache-2.0",
    "private": true,
    "type": "module",
    "author": {
        "name": "Weblab",
        "email": "contact@weblab.build"
    },
    "workspaces": [
        "packages/*",
        "apps/*",
        "tooling/*",
        "apps/web/*"
    ],
    "scripts": {
        "build": "bun --filter @weblab/web build:client",
        "start": "bun --filter @weblab/web start:client",
        "dev": "bun --filter @weblab/web dev",
        "test": "bun --filter '*' test",
        "docs": "bun --filter @weblab/docs dev",
        "dev:admin": "bun --filter @weblab/admin dev",
        "backend:start": "bun --filter @weblab/backend start",
        "db:gen": "bun --filter @weblab/db db:gen",
        "db:push": "cd packages/db && bun db:push",
        "db:seed": "cd packages/db && bun db:seed",
        "db:migrate": "cd packages/db && bun db:migrate",
        "db:reset": "cd apps/backend && bun run reset",
        "format": "bun --filter '*' format",
        "lint": "bun --filter '*' lint",
        "typecheck": "bun --filter @weblab/web-client typecheck",
        "clean": "git clean -xdf node_modules",
        "clean:workspaces": "bun --filter '*' clean",
        "clear": "find . -name 'node_modules' -not -path '*/.git/*' -prune -exec rm -rf {} + ; find . -name '.next' -not -path '*/.git/*' -prune -exec rm -rf {} + ; find . -name '.turbo' -not -path '*/.git/*' -prune -exec rm -rf {} + ; find . -name 'dist' -not -path '*/.git/*' -prune -exec rm -rf {} + ; bun install",
        "kill": "lsof -ti:3000,3001,3002,4000 | xargs kill -9 2>/dev/null || true",
        "setup:env": "cd packages/scripts && bun run start",
        "docker:build": "docker compose build",
        "docker:up": "docker compose up -d",
        "docker:down": "docker compose down",
        "docker:logs": "docker compose logs -f",
        "docker:restart": "docker compose down && docker compose up -d --build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Ludvig-Hedin/Weblab.git"
    },
    "bugs": {
        "url": "https://github.com/Ludvig-Hedin/Weblab/issues"
    },
    "devDependencies": {
        "@weblab/eslint": "*"
    },
    "ignoredBuildScripts": ["better-sqlite3"],
    "packageManager": "bun@1.3.1"
}
