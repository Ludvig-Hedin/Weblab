{
    "name": "@weblab/web-preload",
    "module": "script/index.ts",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"bun run build:preload:watch\" \"bun run build:ix:watch\" \"bun run serve\"",
        "serve": "bun --watch server/index.ts",
        "build": "bun run build:preload && bun run build:ix",
        "build:preload": "bun build script/index.ts --outfile=../client/public/weblab-preload-script.js --target=browser --minify --external @weblab/utility",
        "build:preload:watch": "bun run build:preload --watch",
        "build:ix": "bun build ix-runtime/index.ts --outfile=../client/public/weblab-ix-runtime.js --target=browser --minify",
        "build:ix:watch": "bun run build:ix --watch",
        "build:watch": "bun run build:preload:watch",
        "lint": "eslint . --max-warnings 0",
        "format": "eslint --fix .",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@weblab/eslint": "*",
        "@weblab/typescript": "*",
        "@types/bun": "latest",
        "@types/css-tree": "^2.3.10",
        "@types/lodash.debounce": "^4.0.9",
        "concurrently": "^9.1.2",
        "eslint": "^9.0.0",
        "typescript": "^5.5.4"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@weblab/constants": "*",
        "@weblab/models": "*",
        "@weblab/penpal": "*",
        "css-tree": "^3.1.0",
        "lodash-es": "^4.17.21",
        "lodash.debounce": "^4.0.8",
        "nanoid": "^5.1.5",
        "penpal": "^7.0.4"
    }
}
