# ---------------------------------------------------------------------------
# .env.prod.example  —  template for `bun dev:prod`
# ---------------------------------------------------------------------------
# Copy this file to `.env.prod.local` and fill in the prod secrets, then run:
#
#     bun dev:prod        (from repo root — local frontend on :3000, PROD backend)
#
# How it works: `dev:prod` loads this file with `bun --env-file=.env.prod.local`
# BEFORE Next.js boots. Next never overwrites vars already present in
# process.env, so every var listed here overrides the matching value in
# `.env.local`. Any var NOT listed here falls back to `.env.local`.
#
# ⚠️  DANGER: this points your LOCAL frontend at REAL PRODUCTION data.
#     UI writes (settings, projects, billing, etc.) hit prod. Use only for
#     read-only UI verification, or know exactly what you are mutating.
#
# `.env.prod.local` is gitignored (apps/web/client/.gitignore `.env*.local`).
# NEVER commit real keys. This `.example` file holds placeholders only.
# ---------------------------------------------------------------------------

# --- Convex (prod deployment: rapid-crab-113) ------------------------------
NEXT_PUBLIC_CONVEX_URL="https://rapid-crab-113.convex.cloud"
CONVEX_URL="https://rapid-crab-113.convex.cloud"
CONVEX_SITE_URL="https://rapid-crab-113.convex.site"
CONVEX_DEPLOYMENT="prod:rapid-crab-113"

# --- Supabase (prod project) -----------------------------------------------
# Fill from the prod Supabase project's API settings (Project Settings → API).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROD_PROJECT.supabase.co"
SUPABASE_URL="https://YOUR_PROD_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_PROD_SUPABASE_ANON_KEY"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_PROD_SUPABASE_PUBLISHABLE_KEY"
# Server-only — only needed if you exercise server actions/routes that use it:
# SUPABASE_SERVICE_ROLE_KEY="YOUR_PROD_SERVICE_ROLE_KEY"
# SUPABASE_DATABASE_URL="postgresql://...prod..."

# --- Clerk (prod / live instance) ------------------------------------------
# Prod uses LIVE keys (pk_live_… / sk_live_…). Fill from the prod Clerk app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_YOUR_PROD_KEY"
CLERK_SECRET_KEY="sk_live_YOUR_PROD_SECRET"
CLERK_FRONTEND_API_URL="https://clerk.weblab.build"
CLERK_JWT_ISSUER_DOMAIN="https://clerk.weblab.build"

# NOTE: leave NEXT_PUBLIC_SITE_URL unset here — it stays http://localhost:3000
# (from .env.local) because the frontend is running locally.
