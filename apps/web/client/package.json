    "type": "module",
    "scripts": {
        "dev": "lsof -ti:3000 | xargs kill -9 2>/dev/null; next dev --turbo --port 3000",
        "convex:dev": "convex dev",
        "convex:deploy": "convex dev --once",
        "convex:codegen": "convex codegen",
        "lint": "eslint . --max-warnings 5000",
        "format": "eslint --fix .",
        "typecheck": "tsc --noEmit",
        "prebuild": "bun run ../../../packages/ai/scripts/generate-skills.ts",
        "build": "next build",
        "start": "next start",
        "preview": "bun run build && bun run start",
        "build:standalone": "STANDALONE_BUILD=true next build && { cp -r public .next/standalone/apps/web/client/ && cp -r .next/static .next/standalone/apps/web/client/.next/; } 2>/dev/null",
        "start:standalone": "bun .next/standalone/apps/web/client/server.js",
        "preview:standalone": "bun run build:standalone && bun run start:standalone",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "preview-storybook": "bun --bun x serve storybook-static -p 6007",
        "chromatic": "chromatic --exit-zero-on-changes"
    },
