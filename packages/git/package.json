{
    "name": "@weblab/git",
    "description": "A git library for Weblab",
    "main": "./src/index.ts",
    "type": "module",
    "module": "src/index.ts",
    "types": "src/index.ts",
    "version": "0.0.0",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/Ludvig-Hedin/Weblab.git"
    },
    "scripts": {
        "clean": "rm -rf node_modules",
        "lint": "eslint . --max-warnings 0",
        "format": "eslint --fix .",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "weblab",
        "git"
    ],
    "author": {
        "name": "Weblab",
        "email": "contact@weblab.build"
    },
    "license": "Apache-2.0",
    "homepage": "https://weblab.build",
    "devDependencies": {
        "@weblab/eslint": "*",
        "@weblab/typescript": "*",
        "eslint": "^9.0.0",
        "typescript": "^5.5.4"
    },
    "dependencies": {
        "globby": "^14.1.0",
        "isomorphic-git": "^1.29.0"
    }
}
