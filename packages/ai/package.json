{
    "name": "@weblab/ai",
    "description": "A AI library for Weblab",
    "type": "module",
    "module": "src/index.ts",
    "types": "src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./client": "./src/client.ts",
        "./server": "./src/server.ts"
    },
    "version": "0.0.0",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/Ludvig-Hedin/Weblab.git"
    },
    "scripts": {
        "clean": "rm -rf node_modules",
        "lint": "eslint . --max-warnings 0",
        "format": "eslint --fix .",
        "typecheck": "tsc --noEmit",
        "generate:skills": "bun run scripts/generate-skills.ts"
    },
    "keywords": [
        "weblab",
        "AI"
    ],
    "author": {
        "name": "Weblab",
        "email": "contact@weblab.build"
    },
    "license": "Apache-2.0",
    "homepage": "https://weblab.build",
    "devDependencies": {
        "@weblab/eslint": "*",
        "@weblab/typescript": "*",
        "eslint": "^9.0.0",
        "typescript": "^5.5.4"
    },
    "dependencies": {
        "@ai-sdk/openai": "^2",
        "@mendable/firecrawl-js": "^1.29.1",
        "@openrouter/ai-sdk-provider": "^1.2.0",
        "@weblab/ui": "*",
        "ai": "5.0.60",
        "exa-js": "^1.8.26",
        "fg": "^0.0.3",
        "gpt-tokenizer": "^3.0.1",
        "marked": "^15.0.7",
        "mem0ai": "^2.1.0",
        "ollama-ai-provider-v2": "^3.5.0",
        "openai": "^4.103.0",
        "uuid": "^11.1.0",
        "zod": "^4.1.3"
    }
}
