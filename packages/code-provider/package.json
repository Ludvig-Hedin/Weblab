{
    "name": "@weblab/code-provider",
    "description": "A library with a set of providers for code sandboxing",
    "main": "./src/index.ts",
    "type": "module",
    "module": "src/index.ts",
    "types": "src/index.ts",
    "exports": {
        ".": {
            "browser": "./src/index.browser.ts",
            "default": "./src/index.ts"
        },
        "./providers/vercel-sandbox": {
            "default": "./src/providers/vercel-sandbox/index.ts"
        }
    },
    "version": "0.0.0",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/Ludvig-Hedin/Weblab.git"
    },
    "scripts": {
        "clean": "rm -rf node_modules",
        "lint": "eslint . --max-warnings 0",
        "format": "eslint --fix .",
        "typecheck": "tsc --noEmit",
        "test": "bun test"
    },
    "keywords": [
        "weblab",
        "sandbox"
    ],
    "author": {
        "name": "Weblab",
        "email": "contact@weblab.build"
    },
    "license": "Apache-2.0",
    "homepage": "https://weblab.build",
    "devDependencies": {
        "@weblab/eslint": "*",
        "@weblab/typescript": "*",
        "eslint": "^9.0.0",
        "typescript": "^5.5.4"
    },
    "dependencies": {
        "@codesandbox/sdk": "^1.1.6",
        "@vercel/sandbox": "1.10.2",
        "@weblab/models": "*",
        "@weblab/parser": "*",
        "@weblab/utility": "*"
    }
}
