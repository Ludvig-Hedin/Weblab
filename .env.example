# Root .env — only vars used by database scripts (drizzle, seeds).
# Next.js env vars go in apps/web/client/.env.local instead.
#
# Scripts that read this file:
#   bun db:push / db:migrate / db:seed  (via packages/db/drizzle.config.ts)
#   bun db:seed:sync-stripe             (via --env-file ../../.env)

# Supabase — required by drizzle and seed scripts
SUPABASE_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_SERVICE_ROLE_KEY="<Your Supabase service role key>"

# Stripe — required by db:seed:sync-stripe
STRIPE_SECRET_KEY="<Your Stripe secret key from https://dashboard.stripe.com/apikeys>"

# Server port
PORT=3000
