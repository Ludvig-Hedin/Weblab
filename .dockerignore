# Build outputs
.next
**/.next
dist
build
*.tsbuildinfo
coverage
.nyc_output

# Dependencies (never send existing node_modules into build context)
node_modules
**/node_modules

# Git / editor
.git
.gitignore
.vscode
.idea
.DS_Store

# Env files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Apps not part of the web client build
apps/desktop
apps/backend
apps/docs
apps/video
apps/web/product-video

# Docs + archive (not code dependencies)
docs

# Template sources (large, not imported by the web client at build time)
template-sources

# Misc assets
assets
.vercel
