# Build outputs
.next
**/.next
dist
build
*.tsbuildinfo
coverage
.nyc_output

# Dependencies (never send existing node_modules into build context)
node_modules
**/node_modules

# Git / editor
.git
.gitignore
.vscode
.idea
.DS_Store

# Env files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Sibling apps aren't built in this image, but bun needs every workspace
# member's package.json to satisfy the frozen lockfile graph, and apps/docs
# additionally needs its source for the fumadocs-mdx postinstall that bun runs
# during `bun install`. So exclude only the heavy render outputs, not the apps
# themselves. (apps/desktop/dist is already covered by the global `dist` rule.)
apps/video/out
apps/web/product-video/out
apps/web/product-video/snapshots
apps/web/product-video/assets

# Docs + archive (not code dependencies)
docs

# Template sources (large, not imported by the web client at build time)
template-sources

# Misc assets
assets
.vercel
